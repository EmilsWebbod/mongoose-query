{
  "name": "@ewb/mongoose-query",
  "version": "1.1.17",
  "type": "module",
  "description": "Parse queries and params to mongoose search. Strips dangerous keys and set corrects options with help of query values.",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "scripts": {
    "dev": "yarn build:watch",
    "build": "tsc",
    "build:watch": "tsc --watch --incremental",
    "lint": "tslint --project \"./tsconfig.json\"",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "postversion": "git push && git push --tags",
    "prepublish": "yarn test && yarn build",
    "preversion": "yarn build"
  },
  "dependencies": {
    "express-mongo-sanitize": "^2.2.0",
    "http-status": "^1.6.2",
    "jsondiffpatch": "^0.4.1"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^13.2.2",
    "mongoose": "^8.4.1",
    "prettier": "^3.8.1",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "mongoose": "*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emilswebbod/mongoose-query.git"
  },
  "keywords": [
    "typescript",
    "npm",
    "translate"
  ],
  "author": "Emils Webbod",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/emilswebbod/mongoose-query/issues"
  },
  "homepage": "https://github.com/emilswebbod/mongoose-query#readme",
  "files": [
    "lib"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  },
  "resolutions": {},
  "packageManager": "pnpm@10.12.1+sha512.f0dda8580f0ee9481c5c79a1d927b9164f2c478e90992ad268bbb2465a736984391d6333d2c327913578b2804af33474ca554ba29c04a8b13060a717675ae3ac"
}
